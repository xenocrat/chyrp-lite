#: modules/post_views/info.php:3
msgid "Post Views"
msgstr "Wyświetlenia wpisów"

#: modules/post_views/info.php:6
msgid "Counts the number of times your posts have been viewed."
msgstr "Zlicza liczbę wyświetleń Twoich wpisów."

#: modules/post_views/info.php:11
msgid "Do you want to remove view counts from the database?"
msgstr "Czy chcesz usunąć liczniki wyświetleń z bazy danych?"

#: modules/post_views/post_views.php:49
msgid "View Count"
msgstr "Liczba wyświetleń"

#: modules/post_views/post_views.php:56
#, php-format
msgid "Download view count for &#8220;%s&#8221;"
msgstr "Pobierz liczbę wyświetleń dla &#8222;%s&#8221;"

#: modules/post_views/post_views.php:91
msgid "Reset View Count?"
msgstr "Zresetować licznik wyświetleń?"

#: modules/post_views/post_views.php:123
msgid "An ID is required to download a view count."
msgstr "Do pobrania liczby wyświetleń wymagane jest ID."

#: modules/post_views/post_views.php:138
msgid "You do not have sufficient privileges to download this view count."
msgstr "Nie masz wystarczających uprawnień, aby pobrać tę liczbę wyświetleń."
